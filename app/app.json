{
  "expo": {
    "name": "ImageToVideo",
    "slug": "image-to-video",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "sdkVersion": "50.0.0",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"]
  }
}
